# ==========================================
# Dependency Directories
# ==========================================
node_modules/
/jspm_packages/
/web_modules/

# ==========================================
# Nx Specific
# ==========================================
# Fully ignoring the .nx folder prevents cross-branch metadata and daemon conflicts
.nx/
*.nx-cloud

# ==========================================
# Build Outputs & Cache
# ==========================================
dist/
build/
.next/
.nuxt/
out/
.docusaurus/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache
tsbuildinfo

# ==========================================
# Environment & Secrets (NEVER track these)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key

# ==========================================
# IDEs and Editors
# ==========================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ / WebStorm
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# Operating System Files
# ==========================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# Logs and Diagnostics
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*