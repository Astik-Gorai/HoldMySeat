{
  "18068546075884345157": {
    "targets": {
      "test": {
        "command": "jest",
        "options": {
          "cwd": "auth-service",
          "env": {
            "TS_NODE_COMPILER_OPTIONS": "{\"moduleResolution\":\"node10\",\"module\":\"commonjs\",\"customConditions\":null}"
          }
        },
        "metadata": {
          "technologies": [
            "jest"
          ],
          "description": "Run Jest Tests",
          "help": {
            "command": "npx jest --help",
            "example": {
              "options": {
                "coverage": true
              }
            }
          }
        },
        "cache": true,
        "inputs": [
          "default",
          "^default",
          "{workspaceRoot}/jest.preset.js",
          {
            "externalDependencies": [
              "jest",
              "@nx/jest",
              "ts-jest"
            ]
          },
          {
            "dependentTasksOutputFiles": "**/*.d.ts",
            "transitive": true
          }
        ],
        "outputs": [
          "{workspaceRoot}\\coverage\\auth-service"
        ]
      }
    }
  },
